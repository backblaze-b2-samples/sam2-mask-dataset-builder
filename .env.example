# Backblaze B2 (required) — S3-compatible API
B2_APPLICATION_KEY_ID=your_key_id
B2_APPLICATION_KEY=your_application_key
B2_BUCKET_NAME=your-bucket-name
B2_REGION=your_b2_region
B2_PUBLIC_URL_BASE=your_public_url_base

# Optional: override the derived S3 endpoint. By default the endpoint is
# computed from B2_REGION as https://s3.{B2_REGION}.backblazeb2.com — set
# this only if you need a custom host.
# B2_ENDPOINT=

# Example of what filled-in values look like (fake — for visual reference only):
# B2_APPLICATION_KEY_ID=00abcdef1234567000000001
# B2_APPLICATION_KEY=<your-application-key-shown-once-at-creation>
# B2_BUCKET_NAME=my-mask-datasets
# B2_REGION=us-west-004
# B2_PUBLIC_URL_BASE=https://my-mask-datasets.s3.us-west-004.backblazeb2.com

# SAM 2 segmentation engine
# HuggingFace Hub model id. The default tiny model runs on CPU; weights
# auto-download from the public Hub on first use (no API key required).
SAM2_MODEL_ID=facebook/sam2.1-hiera-tiny

# Dataset layout on B2
# Source media (ingest) lives under SOURCE_PREFIX; derived runs (masks,
# cut-outs, run.json) live under DATASET_PREFIX. The /dataset explorer is
# scoped to DATASET_PREFIX.
SOURCE_PREFIX=raw/
DATASET_PREFIX=datasets/

# Local dev (all OPTIONAL — sane defaults, only set to override)
# Port the FastAPI backend listens on. `scripts/dev.sh` auto-picks a free
# port if 8000 is busy; `pnpm dev:api` honors this if exported. Default: 8000
# API_PORT=8000
# Base URL the Next.js frontend uses to reach the backend. `scripts/dev.sh`
# sets this automatically to match the chosen API_PORT. Default: http://localhost:8000
# NEXT_PUBLIC_API_URL=http://localhost:8000
